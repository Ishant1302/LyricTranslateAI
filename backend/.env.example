# ─── LyricTranslate AI — Environment Variables ─────────────────────────────
# Copy this file to .env and fill in your real keys.
# Never commit .env to version control!

# ── Anthropic / Claude ────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Whisper model size ────────────────────────────────────────────────────────
# Options: tiny | base | small | medium | large-v3
# Larger = more accurate but slower; 'base' is a good default for local use
WHISPER_MODEL_SIZE=base

# ── Demucs model ─────────────────────────────────────────────────────────────
# Options: htdemucs | htdemucs_ft | htdemucs_6s | mdx | mdx_q
# htdemucs is the default; htdemucs_ft is fine-tuned and slightly better
DEMUCS_MODEL=htdemucs

# ── CORS allowed origin ───────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:5173

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT=10/minute
