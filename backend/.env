# ─── LyricTranslate AI — Environment Variables ─────────────────────────────
# WARNING: Never commit this file to version control!

# ── Required: Anthropic / Claude ────────────────────────────────────────────
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=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

# ── Whisper model size (tiny | base | small | medium | large-v3) ─────────────
# base is a good default — fast and accurate for most languages
WHISPER_MODEL_SIZE=base

# ── Demucs model ─────────────────────────────────────────────────────────────
DEMUCS_MODEL=htdemucs

# ── Speed: Skip vocal isolation (much faster, slight accuracy trade-off) ──────
SKIP_VOCAL_ISOLATION=true

# ── CORS / Frontend ───────────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:5173
